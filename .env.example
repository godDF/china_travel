# Existing chat/planning model
OPENAI_API_KEY=sk-3d1585ac36324578a43224fa27ac81ff

# Standalone Agentic RAG query service
AGENTIC_RAG_API_URL=http://127.0.0.1:8100
AGENTIC_RAG_TIMEOUT_SECONDS=40
# Leave empty while the Agentic RAG service runs in demo/no-auth mode.
AGENTIC_RAG_API_KEY=

# Travel planning DFS search limit (seconds)
PLANNING_DFS_TIMEOUT_SECONDS=30

# OpenAI-compatible BGE-M3 embeddings endpoint (no local model download)
BGE_M3_API_URL=https://your-embedding-provider.example.com
BGE_M3_API_KEY=sk-qnmzgmbyurpwcywfrwcbrirtqqonqqptldyayildvmknxopz
BGE_M3_MODEL=BAAI/bge-m3
BGE_M3_VECTOR_SIZE=1024

# Qdrant
QDRANT_URL=http://127.0.0.1:7333
QDRANT_API_KEY=
QDRANT_COLLECTION=chinatravel_safety_knowledge
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.55

# Local review admin
ADMIN_TOKEN=replace-with-a-strong-token
REVIEW_DB_PATH=./data/reviews.sqlite3

# Optional GoHumanLoop API service that forwards approvals to Feishu
GOHUMANLOOP_API_URL=http://127.0.0.1:9800/api
GOHUMANLOOP_API_KEY=your_gohumanloop_api_key
GOHUMANLOOP_TIMEOUT=300

# Login, durable conversation history and layered memory
APP_DB_PATH=./data/app.sqlite3
AUTH_REQUIRED=true
AUTH_COOKIE_NAME=chinatravel_auth
AUTH_COOKIE_SECURE=false
AUTH_SESSION_DAYS=7
MAX_USER_MESSAGE_CHARS=8000

# Optional bootstrap accounts. When BOOTSTRAP_ADMIN_PASSWORD is empty, the
# local demo may use the existing ADMIN_TOKEN as the first admin password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_USER_USERNAME=demo
BOOTSTRAP_USER_PASSWORD=

# Context budget: system instruction -> relevant long-term memory -> summary
# -> latest six complete turns -> current question.
MEMORY_CONTEXT_TOKEN_BUDGET=8000
MEMORY_RECENT_TURNS=6
MEMORY_MINIMUM_RECENT_TURNS=2
MEMORY_LONG_TERM_TOP_K=5
MEMORY_LONG_TERM_SCORE_THRESHOLD=0.55
MEMORY_LONG_TERM_TOKEN_BUDGET=1000
MEMORY_SUMMARY_TOKEN_BUDGET=1200
MEMORY_SUMMARY_TRIGGER_TOKENS=6000
MEMORY_QDRANT_COLLECTION=chinatravel_user_memory_v1
